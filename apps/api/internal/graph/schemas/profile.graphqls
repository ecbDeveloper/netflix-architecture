type Profile {
  id: ID!
  userId: ID!
  name: String!
  hasParentalControls: Boolean!
  createdAt: String!
  updatedAt: String!
  reviews: [Review!]!
  watchHistories: [WatchHistory!]!
}

input CreateProfileInput {
  name: String!
  hasParentalControls: Boolean
}

input UpdateProfileInput {
  name: String
  hasParentalControls: Boolean
}

extend type Query {
  getProfile(id: ID!): Profile @hasRole(role: MEMBER) @auth
  listProfiles: [Profile!]! @auth
}

extend type Mutation {
  createProfile(input: CreateProfileInput!): Profile! @hasRole(role: MEMBER) @auth
  updateProfile(id: ID!, input: UpdateProfileInput!): Profile! @hasRole(role: MEMBER) @auth
  deleteProfile(id: ID!): Boolean! @hasRole(role: MEMBER) @auth
  selectProfile(id: ID!): ID! @auth
}
