directive @auth on FIELD_DEFINITION
directive @hasRole(role: UserRole!) on FIELD_DEFINITION
directive @profileSelectionIsRequired on FIELD_DEFINITION

enum UserRole {
  ADMIN
  MEMBER
}

input LoginInput {
  email: String!
  password: String!
}

extend type Mutation {
  login(input: LoginInput): String!
  logout: String! @auth
}
