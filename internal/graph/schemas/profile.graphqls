type Profile {
  id: ID!
  userId: ID!
  name: String!
  hasParentalControls: Boolean!
  createdAt: String!
  updatedAt: String!
  reviews: [Review!]!
  watchHistories: [WatchHistory!]!
}

input CreateProfileInput {
  userId: ID!
  name: String!
  hasParentalControls: Boolean
}

input UpdateProfileInput {
  name: String
  hasParentalControls: Boolean
}

extend type Query {
  getProfile(id: ID!): Profile
  listProfiles(userId: ID!): [Profile!]!
}

extend type Mutation {
  createProfile(input: CreateProfileInput!): Profile! @hasRole(role: MEMBER)
  updateProfile(id: ID!, input: UpdateProfileInput!): Profile! @hasRole(role: MEMBER)
  deleteProfile(id: ID!): Boolean! @hasRole(role: MEMBER)
}
