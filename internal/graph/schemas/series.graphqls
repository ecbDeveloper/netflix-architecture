type Series {
  id: ID!
  title: String!
  description: String
  releaseDate: String
  maturityRating: String
  episodes: [Episode!]!
}

input CreateSeriesInput {
  title: String!
  description: String
  releaseDate: String
  maturityRating: String
}

input UpdateSeriesInput {
  title: String
  description: String
  releaseDate: String
  maturityRating: String
}

extend type Query {
  getSeries(id: ID!): Series
  listSeries: [Series!]!
}

extend type Mutation {
  createSeries(input: CreateSeriesInput!): Series! @hasRole(role: ADMIN)
  updateSeries(id: ID!, input: UpdateSeriesInput!): Series! @hasRole(role: ADMIN)
  deleteSeries(id: ID!): Boolean! @hasRole(role: ADMIN)
}
