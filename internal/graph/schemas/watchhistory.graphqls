type WatchHistory {
  id: ID!
  profileId: ID!
  movieId: ID
  episodeId: ID
  watchedAt: String!
  lastPositionSeconds: Int
  isCompleted: Boolean
}

input CreateWatchHistoryInput {
  profileId: ID!
  movieId: ID
  episodeId: ID
  lastPositionSeconds: Int
  isCompleted: Boolean
}

input UpdateWatchHistoryInput {
  lastPositionSeconds: Int
  isCompleted: Boolean
}

extend type Query {
  getWatchHistory(id: ID!): WatchHistory @auth
  listWatchHistories(profileId: ID!): [WatchHistory!]! @auth
}

extend type Mutation {
  createWatchHistory(input: CreateWatchHistoryInput!): WatchHistory! @auth
  updateWatchHistory(id: ID!, input: UpdateWatchHistoryInput!): WatchHistory! @auth
  deleteWatchHistory(id: ID!): Boolean! @auth @hasRole(role: MEMBER)
}
